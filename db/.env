# Глобальные настройки пустого стека PostgreSQL.
# Переменные вида *_CONTAINER_NAME будут добавляться автоматически
# при создании новых сервисов через ops/add_service.sh.

# ===================================================================
# ГЛОБАЛЬНЫЕ НАСТРОЙКИ АВТОБЭКАПОВ
# ===================================================================

# Расписание автобэкапов (cron формат: минуты часы день месяц день_недели)
# Примеры: "0 2 * * *" (каждый день в 02:00), "0 3 * * 0" (воскресенье в 03:00)
BACKUP_SCHEDULE="0 2 * * *"

# Сколько дней хранить бэкапы (старые удаляются автоматически)

# Путь для хранения бэкапов (абсолютный путь)
# === ДЛЯ СЕРВЕРА (раскомментируй при переносе) ===
# BACKUP_DIR="/root/db/db_backups"
# === ДЛЯ ЛОКАЛЬНОЙ РАЗРАБОТКИ (закомментируй при переносе) ===
BACKUP_DIR="/tmp/db_backups"

# Включить автобэкапы (true/false)
BACKUP_ENABLED=true

# Логирование бэкапов
# === ДЛЯ СЕРВЕРА (раскомментируй при переносе) ===
# BACKUP_LOG_FILE="/root/db/ops/backup/backup.log"
# === ДЛЯ ЛОКАЛЬНОЙ РАЗРАБОТКИ (закомментируй при переносе) ===
BACKUP_LOG_FILE="/root/db/ops/backup/backup.log"
BACKUP_LOG_MAX_SIZE_MB=50

# Сжатие бэкапов (gzip, none)
BACKUP_COMPRESSION="gzip"

# Бэкапить только запущенные контейнеры (true/false)
BACKUP_RUNNING_ONLY=true

# Таймаут операций бэкапа в секундах
BACKUP_TIMEOUT=300

# Email для уведомлений об ошибках (оставить пустым для отключения)
BACKUP_NOTIFICATION_EMAIL=""

# ===================================================================
# НАСТРОЙКИ ОЧИСТКИ КОНТЕЙНЕРОВ-ПРИЗРАКОВ
# ===================================================================

# Включить автоочистку контейнеров без соответствующих сервисов (true/false)
CLEANUP_ORPHANS_ENABLED=true
# Реестр контейнеров появится здесь после добавления новых сервисов.

# Storage сервер для хранения бэкапов
BACKUP_STORAGE_SERVER="94.156.112.211"
BACKUP_STORAGE_PATH="/root/backups/pg-stacks"

# GFS ротация бэкапов
BACKUP_DAILY_KEEP=7
BACKUP_WEEKLY_KEEP=4
BACKUP_MONTHLY_KEEP=3
